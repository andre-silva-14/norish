{
  "name": "@norish/shared-server",
  "version": "0.17.0-beta",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./logger": "./src/logger.ts",
    "./media/storage": "./src/media/storage.ts",
    "./media/avatar-cleanup": "./src/media/avatar-cleanup.ts",
    "./recipes/randomizer": "./src/recipes/randomizer.ts",
    "./config/defaults": "./src/config/defaults.ts",
    "./archive/parser": "./src/archive/parser.ts",
    "./caldav/client": "./src/caldav/client.ts",
    "./caldav/sync": "./src/caldav/sync.ts",
    "./ai/providers": "./src/ai/providers/index.ts",
    "./ai/unit-converter": "./src/ai/unit-converter.ts",
    "./ai/utils/category-matcher": "./src/ai/utils/category-matcher.ts",
    "./lib/workspace-paths": "./src/lib/workspace-paths.ts"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json --noCheck",
    "lint": "eslint --flag unstable_native_nodejs_ts_config",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "typecheck": "tsc --noEmit --noCheck",
    "clean": "git clean -xdf .cache .turbo node_modules dist"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.46",
    "@ai-sdk/azure": "^3.0.31",
    "@ai-sdk/deepseek": "^2.0.20",
    "@ai-sdk/google": "^3.0.30",
    "@ai-sdk/groq": "^3.0.24",
    "@ai-sdk/mistral": "^3.0.20",
    "@ai-sdk/openai": "^3.0.30",
    "@ai-sdk/openai-compatible": "^2.0.30",
    "@ai-sdk/perplexity": "^3.0.19",
    "@norish/config": "workspace:*",
    "@norish/db": "workspace:*",
    "@norish/i18n": "workspace:*",
    "@norish/shared": "workspace:*",
    "ai": "^6.0.95",
    "cheerio": "1.2.0",
    "fuse.js": "catalog:",
    "heic-convert": "^2.1.0",
    "jszip": "catalog:",
    "ollama-ai-provider-v2": "^3.3.1",
    "pino": "^10.3.0",
    "pino-pretty": "^13.1.3",
    "sharp": "^0.34.5",
    "tsdav": "^2.1.8",
    "uuid": "13.0.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@norish/eslint-config": "workspace:*",
    "@norish/prettier-config": "workspace:*",
    "@norish/tsconfig": "workspace:*",
    "eslint": "catalog:",
    "prettier": "catalog:"
  },
  "prettier": "@norish/prettier-config"
}
